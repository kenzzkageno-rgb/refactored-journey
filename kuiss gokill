<!DOCTYPE html>
<html>
<head>
    <title>Kuis Super Gokil</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 20px; background: #f5f5f5; }
        button { margin: 5px; padding: 10px 20px; cursor: pointer; border: none; border-radius: 5px; }
        button:hover { background: #ddd; }
        #quiz-container { background: white; padding: 20px; border-radius: 10px; display: inline-block; }
        #timer { margin: 10px; font-weight: bold; color: red; }
        #leaderboard ul { list-style: none; padding: 0; }
        #leaderboard li { margin: 5px 0; }
    </style>
</head>
<body>
    <h1>Kuis Super Gokil</h1>
    <div id="quiz-container">
        <div id="question"></div>
        <div id="options"></div>
        <div id="timer">⏱️ 15 detik</div>
        <button id="nextBtn" style="display:none;">Next</button>
    </div>
    <div id="score" style="display:none;"></div>
    <div id="leaderboard" style="display:none;">
        <h2>Leaderboard 🏆</h2>
        <ul id="boardList"></ul>
    </div>

    <script>
        const questions = [
            { q: "Ibukota Indonesia?", a: ["Jakarta", "Bandung", "Surabaya"], correct: 0 },
            { q: "2 + 2 = ?", a: ["3", "4", "5"], correct: 1 },
            { q: "Bulan paling singkat?", a: ["Februari", "Januari", "Maret"], correct: 0 },
            { q: "Planet terdekat matahari?", a: ["Merkurius", "Mars", "Bumi"], correct: 0 }
        ];

        let currentQuestion = null;
        let score = 0;
        let asked = [];
        let timer;
        let timeLeft = 15;

        function getRandomQuestion() {
            if(asked.length === questions.length) return null;
            let idx;
            do { idx = Math.floor(Math.random() * questions.length); } 
            while(asked.includes(idx));
            asked.push(idx);
            return questions[idx];
        }

        function startTimer() {
            timeLeft = 15;
            const timerEl = document.getElementById("timer");
            timerEl.innerText = `⏱️ ${timeLeft} detik`;
            clearInterval(timer);
            timer = setInterval(() => {
                timeLeft--;
                timerEl.innerText = `⏱️ ${timeLeft} detik`;
                if(timeLeft <= 0) {
                    clearInterval(timer);
                    alert("Waktu habis! ❌");
                    document.getElementById("nextBtn").style.display = "inline-block";
                    Array.from(document.getElementById("options").children).forEach(b => b.disabled = true);
                }
            }, 1000);
        }

        function showQuestion() {
            currentQuestion = getRandomQuestion();
            const questionEl = document.getElementById("question");
            const optionsEl = document.getElementById("options");
            const nextBtn = document.getElementById("nextBtn");
            optionsEl.innerHTML = "";
            nextBtn.style.display = "none";

            if(!currentQuestion) {
                document.getElementById("quiz-container").style.display = "none";
                const scoreEl = document.getElementById("score");
                scoreEl.style.display = "block";
                scoreEl.innerHTML = `Kuis selesai! Skormu: ${score}/${questions.length} 🎉`;
                showLeaderboard();
                return;
            }

            questionEl.innerText = currentQuestion.q;

            currentQuestion.a.forEach((option, index) => {
                const btn = document.createElement("button");
                btn.innerText = option;
                btn.onclick = () => {
                    clearInterval(timer);
                    if(index === currentQuestion.correct){
                        alert("Bener cuy! ✅");
                        score++;
                    } else {
                        alert("Salah!!! ❌");
                    }
                    nextBtn.style.display = "inline-block";
                    Array.from(optionsEl.children).forEach(b => b.disabled = true);
                }
                optionsEl.appendChild(btn);
            });

            startTimer();
        }

        function showLeaderboard() {
            const lb = document.getElementById("leaderboard");
            const boardList = document.getElementById("boardList");
            lb.style.display = "block";
            
            let leaderboard = JSON.parse(localStorage.getItem("leaderboard")) || [];
            let name = prompt("Masukin nama lo buat leaderboard:");
            leaderboard.push({ name: name || "Anon", score: score });
            leaderboard.sort((a,b) => b.score - a.score);
            leaderboard = leaderboard.slice(0,5); // top 5
            localStorage.setItem("leaderboard", JSON.stringify(leaderboard));

            boardList.innerHTML = leaderboard.map(entry => `<li>${entry.name}: ${entry.score}</li>`).join("");
        }

        document.getElementById("nextBtn").onclick = showQuestion;
        showQuestion();
    </script>
</body>
</html>
